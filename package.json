{
  "name": "lvce-startup-benchmark",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark": "node src/main.ts",
    "benchmark:ci": "node src/runCiBenchmark.ts",
    "ci:report": "node src/generateCiReport.ts",
    "ci:resolve-versions": "node src/resolveBenchmarkVersions.ts",
    "install-browser:ci": "playwright install --with-deps chromium",
    "lint": "eslint .",
    "report": "node src/report.ts",
    "test": "node --test \"test/**/*.test.ts\"",
    "type-check": "tsc --noEmit",
    "update-versions": "node src/updateVersions.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@lvce-editor/eslint-config": "^16.4.0",
    "@types/node": "^25.0.1",
    "eslint": "^10.7.0",
    "playwright": "^1.57.0",
    "typescript": "^5.9.3"
  }
}
